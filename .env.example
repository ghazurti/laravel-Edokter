APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Produksi di balik reverse proxy aaPanel: isi nama domain lokalnya,
# mis. APP_URL=http://edokter.rsud.local (tanpa :8090). Tanpa proxy: http://172.17.10.4:8090
APP_URL=http://localhost

# Identitas instansi untuk kop surat cetak (PDF)
NAMA_INSTANSI="NAMA RUMAH SAKIT"
LOGO_INSTANSI=images/logo.png
# Kop surat 2 logo: kiri = lambang kota/pemda, kanan = logo RSUD.
# Default: kiri=images/logo-kota-baubau.png, kanan=LOGO_INSTANSI. Override bila perlu:
# LOGO_KOP_KIRI=images/logo-kota-baubau.png
# LOGO_KOP_KANAN=images/logo-rsud-baubau.png
ALAMAT_INSTANSI="Alamat RS"
KOTA_INSTANSI="Kota"
TELP_INSTANSI=""
EMAIL_INSTANSI=""

# Base URL viewer radiologi / PACS Orthanc (kosongkan kalau lokasi_gambar sudah full URL)
URL_RADIOLOGI=
# Base URL berkas digital (untuk link di riwayat)
BERKAS_BASE_URL=

# ============================================================
# Orthanc PACS bridging (kompatibel dengan Khanza desktop)
# ============================================================
# Replikasi pola Khanza desktop (ApiOrthanc.java). PatientID di Orthanc
# DIASUMSIKAN = no_rkm_medis Khanza — kalau di RS Anda berbeda, mapping
# perlu diubah di OrthancService.
#
# ORTHANC_URL: host Orthanc (TANPA trailing slash, TANPA port).
#   Contoh: http://10.0.0.50 atau https://pacs.rs-internal.local
ORTHANC_URL=http://IP-PACS-ORTHANC
# Port REST API Orthanc (default 8042).
ORTHANC_PORT=8042
# Basic Auth Orthanc — sama persis dengan setting Khanza desktop.
# JANGAN commit credential asli ke git.
ORTHANC_USER=ganti-dengan-user-orthanc
ORTHANC_PASS=ganti-dengan-pass-orthanc
# Timeout HTTP ke Orthanc dalam detik (default 15 cukup untuk LAN).
ORTHANC_TIMEOUT=15
# Folder arsip JPG hasil preview (kosongkan = storage/app/orthanc).
# Direkomendasikan set ke NAS / shared volume agar gambar tetap ada
# meski Orthanc dimatikan atau container Laravel di-rebuild.
#   Contoh Docker: ORTHANC_ARCHIVE_PATH=/var/orthanc-archive (mount volume)
ORTHANC_ARCHIVE_PATH=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ============================================================
# BPJS I-Care / VClaim
# ============================================================
# Credential BPJS di dapat dari SDP BPJS (https://sdp.bpjs-kesehatan.go.id).
# Tiap faskes punya CONS_ID + SECRET + USER_KEY berbeda.
# JANGAN PERNAH commit value asli ke git/GitHub publik.
# Nilai di bawah hanya CONTOH/DUMMY — wajib diganti sesuai faskes Anda.

# CONS_ID = ID consumer faskes (umumnya angka 5 digit)
BPJS_CONS_ID=99999
# CONS_PWD = secret key untuk HMAC SHA-256 signature
BPJS_CONS_PWD=xxxxxxxxxxxxxxx
# USER_KEY = key layanan Vclaim (32 hex digit)
BPJS_USER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# I-Care JKN endpoint
# PENTING: BPJS_ICARE_BASE_URL HARUS lengkap sampai "/api/rs" (TANPA trailing slash).
# Kode akan menambahkan "/validate" otomatis (sama seperti Khanza desktop).
# Path yang umum dipakai BPJS:
#   DEV  : https://apijkn-dev.bpjs-kesehatan.go.id/ihs_dev/api/rs
#   PROD : https://apijkn.bpjs-kesehatan.go.id/ihs/api/rs
# Beberapa rumah sakit pakai endpoint baru "wsihs":
#   PROD : https://apijkn.bpjs-kesehatan.go.id/wsihs/api/rs
# Salah path -> 404 "No Mapping Rule matched".
BPJS_ICARE_BASE_URL=https://apijkn-dev.bpjs-kesehatan.go.id/ihs_dev/api/rs
# user_key khusus layanan I-Care.
# Kosongkan = pakai BPJS_USER_KEY (umum di banyak RS, termasuk RSUD Baubau).
# Isi kalau BPJS kasih user_key terpisah untuk layanan I-Care di faskes Anda.
BPJS_ICARE_USER_KEY=

# VClaim endpoint (SEP, peserta, rujukan, dll)
#   DEV  : https://apijkn-dev.bpjs-kesehatan.go.id/vclaim-rest-dev/
#   PROD : https://apijkn.bpjs-kesehatan.go.id/vclaim-rest/
BPJS_BASE_URL=https://apijkn-dev.bpjs-kesehatan.go.id/vclaim-rest-dev/

# ============================================================
# Khanza AES key (untuk decrypt password user dari tabel Khanza)
# ============================================================
# WAJIB samakan dengan key AES yang dipakai Khanza desktop di RS Anda.
# Cek di Khanza: file properties terenkripsi atau source EnkripsiAES.java.
# Kalau salah, Laravel tidak bisa verifikasi password login dokter.
# Nilai di bawah hanya CONTOH — wajib diganti sesuai Khanza Anda.
KHANZA_AES_USER_KEY=ganti-dengan-aes-user-key-khanza
KHANZA_AES_PASS_KEY=ganti-dengan-aes-pass-key-khanza

# ============================================================
# Berkas Digital Perawatan
# ============================================================
# Folder upload Khanza HYBRIDWEB (webapps/berkasrawat/pages/upload).
# Kalau Laravel & Khanza beda host (mis. Laravel di Docker, Khanza di Windows),
# biarkan kosong → file disimpan di public/webapps/berkasrawat/pages/upload/ Laravel.
# Kalau di-deploy di host yang sama dengan Khanza, set ke path absolut Khanza:
#   BERKAS_UPLOAD_PATH=/www/wwwroot/{nama-site}/webapps/berkasrawat/pages/upload
BERKAS_UPLOAD_PATH=
